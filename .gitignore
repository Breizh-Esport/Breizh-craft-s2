# Ignore everything by default
*

# Keep repository meta/docs
!/.gitignore
!/LICENSE
!/README.md

# Keep modpack manifests
!/minecraftinstance.json
!/pakku.json
!/pakku-lock.json

# Keep tracked config/script trees (including contents)
!/config/
!/config/**
!/defaultconfigs/
!/defaultconfigs/**
!/kubejs/
!/kubejs/**

# Keep CI workflow files
!/.github/
!/.github/**
!/scripts/
!/scripts/**

# Ignore local configs
/config/jei/world/
/config/jei/world/**
/config/spark/activity.json

.probe
